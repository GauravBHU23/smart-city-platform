# Copy this file to .env and fill in your real values.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/smart_city_db

# JWT signing secret. Use a long random string (in production, generate a new one).
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS: "*" for local dev. In production set to your admin panel URL(s),
# comma-separated, e.g. https://your-admin.vercel.app
CORS_ORIGINS=*

# Optional: URL of the AI microservice. Defaults to http://127.0.0.1:8020
# AI_SERVICE_URL=http://127.0.0.1:8020
