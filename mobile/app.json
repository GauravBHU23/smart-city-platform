{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.gauravkum1275.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Smart City to use your location to tag complaints."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Smart City to access your photos to attach to complaints.",
          "cameraPermission": "Allow Smart City to use the camera to photograph issues."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ceaec8c2-23d2-4aae-8f3d-f905c23bb809"
      }
    }
  }
}
